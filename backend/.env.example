MYSQL_HOST=iot.cpe.ku.ac.th
MYSQL_PORT=3306
MYSQL_USER=your_ku_username
MYSQL_PASSWORD=your_ku_password
MYSQL_DATABASE=your_ku_database

MQTT_DEAD_LETTER_PATH=./data/mqtt_dead_letter.json
