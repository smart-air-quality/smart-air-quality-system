WAQI_TOKEN=demo
# https://www.weatherapi.com/ — free tier available
WEATHERAPI_KEY=demo
# Legacy (optional): still read if WEATHERAPI_KEY is unset or "demo"
# OWM_API_KEY=
LOCATION_CITY=Bangkok
LOCATION_LAT=13.7563
LOCATION_LON=100.5018
HOST=0.0.0.0
PORT=8000

# Logging: text | json
LOG_FORMAT=text
# Optional: append JSON lines for rejected MQTT payloads
# MQTT_DEAD_LETTER_PATH=./data/mqtt_dead_letter.jsonl

COLLECTOR_ENABLED=true
COLLECTOR_INTERVAL_SECONDS=900
EXTERNAL_SNAPSHOT_MAX_AGE_MINUTES=45

MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_HOST=host
MYSQL_PORT=port
MYSQL_DATABASE=database_name

# SQLAlchemy pool — defaults: size=1, overflow=0 (one pooled connection per app process).
# max_user_connections on shared MySQL often counts ALL clients (phpMyAdmin, PHP, this API).
# Increase only if the DB user quota allows it.
DATABASE_POOL_SIZE=1
DATABASE_MAX_OVERFLOW=0

# DATABASE_URL=mysql+pymysql://USER:PASSWORD@iot.cpe.ku.ac.th:3306/DATABASE_NAME
