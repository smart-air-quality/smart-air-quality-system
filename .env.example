# Database Hosting (https://iot.cpe.ku.ac.th/pma/)
# Enter your KU credentials below. The system will connect to the university server.
MYSQL_HOST=iot.cpe.ku.ac.th
MYSQL_USER=your_ku_username
MYSQL_PASSWORD=your_ku_password
MYSQL_DATABASE=your_ku_database

# External APIs (Optional)
# Leave as 'demo' to use fallback data, or enter your own API keys.
WAQI_TOKEN=demo
WEATHERAPI_KEY=demo

# Location settings (Bangkok, Thailand)
LOCATION_CITY=Bangkok
LOCATION_LAT=13.7563
LOCATION_LON=100.5018

# Server settings
HOST=0.0.0.0
PORT=8000