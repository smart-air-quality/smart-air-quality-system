# World Air Quality Index API
# Get your free token at https://aqicn.org/data-platform/token/
WAQI_TOKEN=your_waqi_token_here

# OpenWeatherMap API
# Get your free key at https://openweathermap.org/api
OWM_API_KEY=your_openweathermap_key_here

# Location settings (default: Bangkok, Thailand)
LOCATION_CITY=Bangkok
LOCATION_LAT=13.7563
LOCATION_LON=100.5018

# Server settings
HOST=0.0.0.0
PORT=8000
